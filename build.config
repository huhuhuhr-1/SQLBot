# SQLBot Build Configuration
# This file contains configuration options for the build script

[build]
# Build type: all, backend, frontend, g2-ssr, package, docker
type = "all"

# Whether to clean previous builds before building
clean = false

# Whether to skip running tests
skip_tests = false

# Whether to enable parallel building (experimental)
parallel = false

# Whether to enable verbose output
verbose = false

# Whether to perform a dry run (show what would be done without executing)
dry_run = false

[packaging]
# Package name
name = "sqlbot"

# Package description
description = "SQLBot - AI-powered SQL assistant"

# Package vendor
vendor = "SQLBot Team"

# Package license
license = "MIT"

# Package category
category = "Development/Tools"

# Package dependencies
dependencies = [
    "python3.11",
    "nodejs",
    "npm"
]

# Package architecture
architecture = "x86_64"

# Package maintainer
maintainer = "SQLBot Team <team@sqlbot.com>"

[docker]
# Base image for Docker build
base_image = "python:3.11-slim"

# Docker registry (if pushing to registry)
registry = ""

# Docker namespace
namespace = "sqlbot"

# Additional Docker build arguments
build_args = {}

[backend]
# Python version requirement
python_version = "3.11"

# Build tool preference: uv, pip, poetry
build_tool = "uv"

# Whether to include development dependencies
include_dev_deps = false

# Additional build flags
build_flags = []

[frontend]
# Node.js version requirement
node_version = "18"

# Package manager preference: npm, yarn, pnpm
package_manager = "npm"

# Build optimization level: development, production
optimization = "production"

# Whether to include source maps
source_maps = false

[g2-ssr]
# Whether to build g2-ssr as a separate package
separate_package = false

# Build optimization for g2-ssr
optimization = "production"

[logging]
# Log level: DEBUG, INFO, WARN, ERROR
level = "INFO"

# Log file path
file = "build.log"

# Whether to include timestamps in logs
timestamps = true

# Whether to use colored output
colors = true

[environment]
# Environment-specific overrides
development = {}
staging = {}
production = {}

# Custom environment variables
variables = {}

[parallel]
# Number of parallel jobs (0 = auto-detect)
jobs = 0

# Whether to enable parallel building for specific components
backend_parallel = false
frontend_parallel = false
g2_ssr_parallel = false

[cleanup]
# Whether to clean temporary files after build
cleanup_temp = true

# Whether to clean package staging directory
cleanup_staging = false

# Files/directories to clean
clean_patterns = [
    "*.pyc",
    "__pycache__",
    "*.egg-info",
    "build",
    "dist",
    "node_modules",
    ".vite"
]
