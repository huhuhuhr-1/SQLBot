# SQLBot 开发环境配置文件
# 重命名为 .env 并修改参数以匹配您的环境

# SSH 配置
SSH_PORT=22
HOST_SSH_PORT=2222

# 应用端口配置
HOST_BACKEND_PORT=8000
HOST_FRONTEND_PORT=3000
HOST_MCP_PORT=8001

# 调试配置
DEBUG_MODE=false
PY_DEBUG_PORT=5678
HOST_DEBUG_PORT=5678

# 服务启动配置
# 是否自动启动后端服务 (true/false)
# 设为 false 可让 PyCharm 或手动启动服务，避免端口冲突
START_SERVICES=true

# 数据库配置
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=root
POSTGRES_PASSWORD=Password123@pg
POSTGRES_DB=sqlbot

# 代码挂载
MOUNT_CODE=false