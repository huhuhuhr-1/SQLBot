# 简化版测试镜像
FROM registry.cn-qingdao.aliyuncs.com/dataease/sqlbot-base:latest

ENV SQLBOT_HOME=/opt/sqlbot
ENV PYTHONPATH=${SQLBOT_HOME}/app

# Create user
USER root
RUN useradd -m -s /bin/bash sqlbot \
 && echo 'sqlbot:sqlbot' | chpasswd \
 && usermod -aG sudo sqlbot \
 && echo "sqlbot ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Install SSH
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server \
  && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/run/sshd

# Configure SSH
RUN sed -i "s/#Port 22/Port 22/g" /etc/ssh/sshd_config || true \
 && sed -i "s/#PasswordAuthentication yes/PasswordAuthentication yes/g" /etc/ssh/sshd_config || true \
 && sed -i "s/#PermitRootLogin prohibit-password/PermitRootLogin no/g" /etc/ssh/sshd_config || true

# Create app directory
RUN mkdir -p ${SQLBOT_HOME}/app
COPY build/dev/start-container.sh ${SQLBOT_HOME}/app/start-container.sh
RUN chmod +x ${SQLBOT_HOME}/app/start-container.sh

# Expose ports
EXPOSE 22 8000 3000 5678

USER sqlbot
WORKDIR ${SQLBOT_HOME}/app

ENTRYPOINT ["sh", "start-container.sh"]