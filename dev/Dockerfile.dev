# SQLBot开发环境
FROM registry.cn-qingdao.aliyuncs.com/dataease/sqlbot-base:latest

# 设置环境变量
ENV PYTHONUNBUFFERED=1
ENV SQLBOT_HOME=/opt/sqlbot
ENV PYTHONPATH=${SQLBOT_HOME}/app
ENV PATH="${SQLBOT_HOME}/app/.venv/bin:$PATH"

# 设置编码
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# 配时区
RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

# 配置pip使用国内源
RUN mkdir -p ~/.pip && \
    echo "[global]" > ~/.pip/pip.conf && \
    echo "index-url = https://mirrors.aliyun.com/pypi/simple/" >> ~/.pip/pip.conf && \
    echo "trusted-host = mirrors.aliyun.com" >> ~/.pip/pip.conf && \
    echo "timeout = 120" >> ~/.pip/pip.conf

# 配置npm使用国内源
RUN npm config set registry https://registry.npmmirror.com && \
    npm config set fund false && \
    npm config set audit false

# 创建工作目录
WORKDIR /workspace

# 安装开发工具和网络工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    vim \
    curl \
    wget \
    htop \
    tree \
    unzip \
    build-essential \
    net-tools \
    dnsutils \
    iputils-ping \
    netcat-openbsd \
    tcpdump \
    && rm -rf /var/lib/apt/lists/*

# 安装uv最新版本
RUN pip install uv

# 复制SQLBot项目文件
COPY . /workspace/sqlbot

# 创建虚拟环境并安装Python依赖
WORKDIR /workspace/sqlbot/backend
RUN uv venv /workspace/sqlbot/backend/.venv && \
    uv pip install --index-url https://mirrors.aliyun.com/pypi/simple/ -e .

# 安装前端依赖
WORKDIR /workspace/sqlbot/frontend
RUN npm install

# 安装g2-ssr依赖
WORKDIR /workspace/sqlbot/g2-ssr
RUN npm install

# 设置bash配置
RUN echo 'export PS1="\[\033[01;32m\]\u@sqlbot-dev\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ "' >> ~/.bashrc && \
    echo 'cd /workspace/sqlbot' >> ~/.bashrc && \
    echo 'source /workspace/sqlbot/backend/.venv/bin/activate' >> ~/.bashrc

# 创建开发脚本
RUN echo '#!/bin/bash\n\
echo "SQLBot开发环境启动脚本"\n\
echo "工作目录: /workspace/sqlbot"\n\
echo "Python版本: $(python --version)"\n\
echo "Node.js版本: $(node --version)"\n\
echo "启动后端服务器: cd backend && uvicorn main:app --host 0.0.0.0 --port 8000 --reload"\n\
echo "启动前端服务器: cd frontend && npm run dev"\n\
echo "启动g2-ssr服务器: cd g2-ssr && npm start"\n\
' > /workspace/sqlbot/dev-start.sh && \
    chmod +x /workspace/sqlbot/dev-start.sh

# 设置启动目录
WORKDIR /workspace/sqlbot

# 暴露端口
EXPOSE 3000 8000 8001

# 设置默认命令
CMD ["/bin/bash"]